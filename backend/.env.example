# ===========================================
# Mizan Platform - Backend Configuration
# ===========================================

# Server
PORT=5001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/mizan
DB_POOL_MAX=20

# Redis (caching, sessions, rate limiting, job queues)
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your-jwt-secret-min-32-chars

# === AI Engines (Three-Engine Architecture) ===

# Knowledge Engine (Mistral AI) — Fast lookups, FAQs, intent classification
MISTRAL_API_KEY=your-mistral-api-key
MISTRAL_MODEL=mistral-large-latest

# Reasoning Engine (Anthropic Claude) — Deep analysis, recommendations
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-sonnet-4-20250514

# Data Engine (Google Gemini) — Analytics, data processing, reports
GOOGLE_AI_API_KEY=your-google-ai-api-key
GEMINI_MODEL=gemini-1.5-pro

# === External Services ===

# Email (SendGrid)
SENDGRID_API_KEY=your-sendgrid-key
SENDGRID_FROM_EMAIL=noreply@mizan.ai

# Storage (S3-compatible)
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=us-east-1
S3_BUCKET=mizan-storage

# === Error Tracking ===
SENTRY_DSN=your-sentry-dsn
